<Window x:Class="TanksGame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Танчики WPF" Height="700" Width="620"
        Background="#222"
        KeyDown="Window_KeyDown" KeyUp="Window_KeyUp">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#333" Padding="10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Счет: " Foreground="White" FontWeight="Bold"/>
                <TextBlock x:Name="TxtScore" Text="0" Foreground="Yellow" Margin="0,0,20,0"/>

                <TextBlock Text="Жизни: " Foreground="White" FontWeight="Bold"/>
                <TextBlock x:Name="TxtLives" Text="3" Foreground="Red" Margin="0,0,20,0"/>

                <TextBlock Text="Рекорд: " Foreground="White" FontWeight="Bold"/>
                <TextBlock x:Name="TxtHighScore" Text="0" Foreground="LightGreen"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" BorderBrush="#555" BorderThickness="2" Margin="10">
            <Canvas x:Name="GameCanvas" Background="Black" Width="600" Height="600" Focusable="True"/>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Content="Выход" Width="100" Height="30" Click="BtnExit_Click" Focusable="False"/>
            <Button Content="Рестарт" Width="100" Height="30" Margin="10,0,0,0" Click="BtnRestart_Click" Focusable="False"/>
        </StackPanel>

        <Grid x:Name="GameOverOverlay" Visibility="Collapsed" Background="#AA000000" Grid.Row="1">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="TxtGameOverMsg" Text="GAME OVER" Foreground="White" FontSize="32" HorizontalAlignment="Center"/>
                <Button Content="Играть снова" Margin="0,20,0,0" Width="150" Height="40" Click="BtnRestart_Click" Focusable="False"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>